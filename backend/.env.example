# MongoDB Atlas connection string (get from atlas.mongodb.com)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/hackvote

# Port (Render sets this automatically, don't change)
PORT=5000

# Admin PIN
ADMIN_PIN=1234

# Your Vercel frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.vercel.app
